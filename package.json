{
  "name": "kaan-luum-control",
  "version": "1.0.0",
  "description": "Sistema de control de brazaletes para cenote Laguna de Kaan Luum",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "test": "node --test",
    "electron": "electron .",
    "dist": "electron-builder --win --x64",
    "dist-portable": "electron-builder --win portable --x64"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "mx.kaanluum.pos",
    "productName": "Kaan Luum POS",
    "copyright": "Laguna de Kaan Luum, Tulum",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**",
      "!**/*.md",
      "!docs/**",
      "!test/**",
      "!herramientas/**",
      "!build/**",
      "!database-postgres.js",
      "!vercel.json",
      "!reset-db.js",
      "!.gitignore"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "public/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kaan Luum POS",
      "runAfterFinish": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "include": "build/installer.nsh"
    },
    "extraResources": [
      { "from": "herramientas", "to": "herramientas" }
    ],
    "protocols": []
  }
}
